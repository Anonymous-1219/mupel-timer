{
  "expo": {
    "name": "Mupel Clock",
    "slug": "mupel-clock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0B0B0F"
    },
    "android": {
      "package": "com.mupel.clock",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0F"
      },
      "permissions": [
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_SPECIAL_USE",
        "SYSTEM_ALERT_WINDOW",
        "WAKE_LOCK"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7C4DFF"
        }
      ],
      "./plugins/withFloatingOverlay.js",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "ec489416-f1c9-4cc9-821f-e26214b69d65"
      }
    }
  }
}
